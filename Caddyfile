# Caddyfile — fmss.ae with auto-HTTPS + subdomains for other projects
# Requires: DNS A records pointing to the server IP, and Caddy installed + running as systemd service

# SAMS — main Sports Academy Management System
fmss.ae {
  log {
    output stdout
    format json
  }

  # Reverse proxy to the Node.js app running on localhost:3000
  reverse_proxy localhost:3000 {
    # Headers for secure cookies (if app doesn't set them)
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
    header_up X-Forwarded-Host {http.request.host}
  }

  # Compression for JSON, HTML, CSS, JS
  encode gzip

  # Security headers
  header / {
    -Server
    Strict-Transport-Security max-age=31536000
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    X-XSS-Protection "1; mode=block"
  }
}

# ========================================================================
# Subdomains for your other projects
# ========================================================================

# Annual Day Quiz — team-based multi-round quiz with live scoring
quiz.fmss.ae {
  log {
    output stdout
    format json
  }
  reverse_proxy localhost:3001 {
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
    header_up X-Forwarded-Host {http.request.host}
  }
  encode gzip
  header / {
    -Server
    Strict-Transport-Security max-age=31536000
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
  }
}

# FMSS Contracts — football contract & fee management
contracts.fmss.ae {
  log {
    output stdout
    format json
  }
  reverse_proxy localhost:3002 {
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
    header_up X-Forwarded-Host {http.request.host}
  }
  encode gzip
  header / {
    -Server
    Strict-Transport-Security max-age=31536000
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
  }
}

# Redirect www.fmss.ae → fmss.ae (clean URLs)
www.fmss.ae {
  redir https://fmss.ae{uri} permanent
}
