# Caddyfile — fmss.ae architecture
# fmss.ae = FMSS Football Club (main site)
# sams.fmss.ae, quiz.fmss.ae, contracts.fmss.ae = specialized subdomains

# ========================================================================
# FMSS Football Club — main public/admin site for the club
# ========================================================================
fmss.ae {
  log {
    output stdout
    format json
  }

  # Reverse proxy to your FMSS club app (from your other chat)
  # Update port 8000 to wherever your club site runs
  reverse_proxy localhost:8000 {
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
    header_up X-Forwarded-Host {http.request.host}
  }

  encode gzip

  header / {
    -Server
    Strict-Transport-Security max-age=31536000
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    X-XSS-Protection "1; mode=block"
  }
}

# ========================================================================
# Subdomains — specialized tools
# ========================================================================

# SAMS — Sports Academy Management System (for team/academy management)
sams.fmss.ae {
  log {
    output stdout
    format json
  }

  reverse_proxy localhost:3000 {
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
    header_up X-Forwarded-Host {http.request.host}
  }

  encode gzip

  header / {
    -Server
    Strict-Transport-Security max-age=31536000
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    X-XSS-Protection "1; mode=block"
  }
}

# Annual Day Quiz — team-based multi-round quiz with live scoring
quiz.fmss.ae {
  log {
    output stdout
    format json
  }

  reverse_proxy localhost:3001 {
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
    header_up X-Forwarded-Host {http.request.host}
  }

  encode gzip

  header / {
    -Server
    Strict-Transport-Security max-age=31536000
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
  }
}

# FMSS Contracts — football contract & fee management
contracts.fmss.ae {
  log {
    output stdout
    format json
  }

  reverse_proxy localhost:3002 {
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
    header_up X-Forwarded-Host {http.request.host}
  }

  encode gzip

  header / {
    -Server
    Strict-Transport-Security max-age=31536000
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
  }
}

# Redirect www.fmss.ae → fmss.ae (clean URLs)
www.fmss.ae {
  redir https://fmss.ae{uri} permanent
}
