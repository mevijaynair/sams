# SAMS production environment variables

# Node.js environment — MUST be 'production' for secure cookies + no demo data
NODE_ENV=production

# JWT secret for signing tokens — use a long random string (minimum 32 characters)
# Generate via: openssl rand -hex 32
JWT_SECRET=your-long-random-secret-here-at-least-32-characters

# Database path — SQLite file must be on persistent disk (not ephemeral)
# Example: /data/sams.db (on a mounted volume in Docker/VPS)
SAMS_DB_PATH=/data/sams.db

# Resend email API key — get it from https://resend.com after signing up
# Without this, password reset emails log to console instead of sending
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Email sender (must be a verified domain in Resend)
# Example: SAMS <no-reply@fmss.ae>
EMAIL_FROM=SAMS <no-reply@fmss.ae>

# Public app URL — used in password reset links emailed to users
# MUST be HTTPS in production
APP_URL=https://fmss.ae

# Port to listen on (optional, defaults to 3000)
PORT=3000
